{
  "name": "a12-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "verify": "tsx scripts/verify.ts",
    "verify:rbac": "tsx scripts/verify-rbac.ts",
    "verify:pages": "tsx scripts/verify-pages.ts",
    "verify:onboarding": "NODE_OPTIONS=--conditions=react-server tsx scripts/verify-onboarding.ts",
    "verify:responsive": "node scripts/verify-responsive.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "setup": "prisma migrate deploy && prisma generate && prisma db seed",
    "vercel-build": "node scripts/patch-turso-schema.mjs && prisma generate && next build",
    "postinstall": "prisma generate",
    "db:turso": "node scripts/migrate-turso.mjs"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@next/env": "^16.2.10",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "puppeteer-core": "^25.3.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
