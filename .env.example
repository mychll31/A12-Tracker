# SQLite keeps local setup at zero. To move to Postgres, change the datasource
# provider in prisma/schema.prisma to "postgresql" and swap the adapter in
# src/lib/db.ts to @prisma/adapter-pg — no model changes are required.
DATABASE_URL="file:./dev.db"

# Signs the session JWT. Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
