# Postgres connection string. Use the pooled/runtime URL here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Optional direct connection for Prisma schema commands and migrations.
# Falls back to DATABASE_URL when unset.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Signs the session JWT. Generate with: openssl rand -base64 32
AUTH_SECRET="run: openssl rand -base64 32"

# Optional. Bearer token for POST /api/cron/recalculate.
# CRON_SECRET="generate-with-openssl-rand-base64-32"
